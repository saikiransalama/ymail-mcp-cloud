{
  "name": "@ymail-mcp/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ymail-mcp/shared-types": "workspace:*",
    "@ymail-mcp/db": "workspace:*",
    "@ymail-mcp/security": "workspace:*",
    "@ymail-mcp/observability": "workspace:*",
    "@ymail-mcp/mailbox-core": "workspace:*",
    "@ymail-mcp/provider-yahoo": "workspace:*",
    "bullmq": "^5.7.0",
    "ioredis": "^5.3.2",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
