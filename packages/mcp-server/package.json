    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ymail-mcp/shared-types": "workspace:*",
    "@ymail-mcp/mailbox-core": "workspace:*",
    "@ymail-mcp/provider-yahoo": "workspace:*",
    "@ymail-mcp/security": "workspace:*",
    "@ymail-mcp/db": "workspace:*",
    "@ymail-mcp/observability": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "ioredis": "^5.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
