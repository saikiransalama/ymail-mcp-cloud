    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ymail-mcp/shared-types": "workspace:*",
    "pino": "^9.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pino-pretty": "^11.2.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
