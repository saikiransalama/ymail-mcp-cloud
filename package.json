{
  "name": "ymail-mcp-cloud",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-user remote MCP server for Yahoo Mail — production-style portfolio project",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "migrate": "pnpm --filter @ymail-mcp/db migrate",
    "migrate:generate": "pnpm --filter @ymail-mcp/db generate",
    "migrate:push": "pnpm --filter @ymail-mcp/db push",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "eslint": "^9.7.0",
    "prettier": "^3.3.3",
    "turbo": "^2.0.9",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "@vitest/coverage-v8": "^2.0.5",
    "tsx": "^4.16.2"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.9.3"
    }
  }
}
